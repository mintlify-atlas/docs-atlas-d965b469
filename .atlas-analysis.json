  "keyFeatures": [
    "Visual AI workflow builder with drag-and-drop canvas",
    "RAG pipeline with document ingestion (PDF, PPT, etc.) and retrieval",
    "Agent capabilities with 50+ built-in tools (Google Search, DALL·E, WolframAlpha)",
    "Support for 100+ LLM providers (OpenAI, Anthropic, Mistral, Llama, etc.)",
    "Prompt IDE for crafting and comparing model outputs",
    "LLMOps observability: logs, annotations, performance monitoring",
    "Backend-as-a-Service REST APIs for all app capabilities",
    "Plugin system and MCP (Model Context Protocol) tool support",
    "Multi-tenant workspace with enterprise SSO and access control",
    "Self-hostable via Docker Compose or Kubernetes"
  ],
  "publicApiSurface": [
    "POST /v1/chat-messages — Send chat messages (blocking/streaming)",
    "POST /v1/completion-messages — Create text completions",
    "POST /v1/workflows/run — Execute a workflow",
    "GET /v1/conversations — List conversations",
    "POST /v1/files/upload — Upload files for use in messages",
    "POST /v1/audio/speech-to-text — Transcribe audio",
    "POST /v1/audio/text-to-speech — Convert text to audio",
    "GET /v1/messages — Get message history",
    "POST /v1/datasets — Create knowledge base",
    "POST /v1/datasets/{dataset_id}/document/create-by-text — Add document",
    "GET /v1/datasets/{dataset_id}/documents — List documents",
    "DELETE /v1/datasets/{dataset_id}/documents/{document_id} — Delete document"
  ]
